{
  "name": "bquery",
  "type": "module",
  "version": "4.0.0",
  "description": "An extended library of interaction between blazor and js. And The name mimics jQuery.",
  "main": "bQuery.js",
  "scripts": {
    "dev": "vite build --config vite.config.js --mode development && node -e \"require('fs').copyFileSync('dist/bQuery.min.js','bQuery.min.js')\"",
    "build": "vite build --config vite.config.js --mode production && node -e \"require('fs').copyFileSync('dist/bQuery.min.js','bQuery.min.js')\"",
    "format": "biome format --write",
    "lint": "biome lint",
    "lint:fix": "biome lint --write",
    "check": "biome check --write"
  },
  "keywords": [
    "bquery",
    "blazor",
    "interop"
  ],
  "author": "zxyao",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@types/node": "^25.3.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.2"
  }
}
